# ── App ───────────────────────────────────────────────────────────────────────
# development → SQLite (auto)   |   staging / production → PostgreSQL (auto)
APP_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to auto-derive from APP_ENV (recommended).
# Set explicitly to override, e.g. for a remote dev database.
DATABASE_URL=

# Required for staging/production (APP_ENV != development):
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=modkit

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=d364b6b320a453e3225b4cd22ab51008b607dea78130d2d47ea69bcc2adc51b3

DEBUG=false
COOKIE_SECURE=false          # true in production (requires HTTPS)
COOKIE_DOMAIN=localhost
COOKIE_SAMESITE=lax

CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
